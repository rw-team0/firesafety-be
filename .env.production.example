# 운영 .env.production 템플릿.
# 실제 값은 이 파일이 아니라 서버에만 있는 .env.production에 채운다. 여기엔 절대 실값 넣지 말 것.
# docker-compose.yml의 firesafety-backend/ai-service가 이 파일을 env_file로 읽는다.

# docker-compose 내부 네트워크 기준 (컨테이너명이 곧 호스트명)
DB_URL=jdbc:mysql://mysql:3306/firesafety
DB_USERNAME=change-me
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me

SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8080

JWT_ISSUER=firesafety
JWT_BEARER_FORMAT=JWT
JWT_CLAIM_KEY=user
JWT_SECRET_KEY=replace_with_base64url_encoded_secret
JWT_ACCESS_TOKEN_COOKIE_NAME=at
JWT_ACCESS_TOKEN_COOKIE_PATH=/
JWT_ACCESS_TOKEN_COOKIE_VALIDITY_SECONDS=3600
JWT_ACCESS_TOKEN_VALIDITY_MILLISECONDS=3600000
JWT_REFRESH_TOKEN_COOKIE_NAME=rt
JWT_REFRESH_TOKEN_COOKIE_PATH=/api/auth
JWT_REFRESH_TOKEN_COOKIE_VALIDITY_SECONDS=604800
JWT_REFRESH_TOKEN_VALIDITY_MILLISECONDS=604800000
# 운영은 HTTPS로만 서비스하므로 반드시 true (local/dev만 false)
JWT_COOKIE_SECURE=true

# 최초 배포 시에만 true로 계정 생성 후 false로 되돌릴 것
BOOTSTRAP_SUPER_ADMIN_ENABLED=false
BOOTSTRAP_SUPER_ADMIN_EMAIL=
BOOTSTRAP_SUPER_ADMIN_PASSWORD=
BOOTSTRAP_SUPER_ADMIN_NAME=최고관리자
BOOTSTRAP_SUPER_ADMIN_PHONE=

FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=

# ai-service 컨테이너와 내부 네트워크로만 통신 (외부 노출 없음)
AI_PREDICTION_ENABLED=false
AI_PREDICTION_BASE_URL=http://ai-service:8000
AI_PREDICTION_PATH=/predict
AI_PREDICTION_MIN_SAMPLE_SIZE=30
AI_PREDICTION_SAMPLE_SIZE=60
AI_PREDICTION_SCHEDULER_DELAY_MS=60000
AI_PREDICTION_SCHEDULER_INITIAL_DELAY_MS=60000

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=change-me
MAIL_PASSWORD=change-me
MAIL_FROM_ADDRESS=change-me
MAIL_FROM_NAME=아크가드 ArcGuard

# 실제 도메인 확정 전까지 플레이스홀더 (nginx server_name과 맞출 것)
PASSWORD_RESET_BASE_URL=https://firesafety.example.internal/reset-password
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30
PASSWORD_RESET_RATE_LIMIT_WINDOW_MINUTES=10
PASSWORD_RESET_RATE_LIMIT_MAX_COUNT=5

COMMUNICATION_LOST_CHECK_DELAY_MS=30000
COMMUNICATION_LOST_CHECK_INITIAL_DELAY_MS=30000

# 운영에서는 반드시 false (실제 장비 연결)
SENSOR_MOCK_ENABLED=false
SENSOR_MOCK_DELAY_MS=5000
