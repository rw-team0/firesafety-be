<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rayworld.firesafety.alert.mapper.AlertMapper">
    <!-- 경보 발생 이력 저장 -->
    <insert id="insertAlert"
            parameterType="com.rayworld.firesafety.alert.model.Alert"
            useGeneratedKeys="true"
            keyProperty="alertId">
        INSERT INTO alert (
            circuit_id,
            panel_id,
            source,
            type,
            result_id,
            status
        ) VALUES (
            #{circuitId},
            #{panelId},
            #{source},
            #{type},
            #{resultId},
            #{status}
        )
    </insert>
</mapper>
