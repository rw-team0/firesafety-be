<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rayworld.firesafety.facility.mapper.UserSiteMapper">
    <resultMap id="userSiteAssignmentResultMap"
               type="com.rayworld.firesafety.facility.model.UserSiteAssignment">
        <id property="mappingId" column="mapping_id"/>
        <result property="userId" column="user_id"/>
        <result property="siteId" column="site_id"/>
        <result property="siteName" column="site_name"/>
        <result property="siteAddress" column="site_address"/>
        <result property="assignedAt" column="assigned_at"/>
    </resultMap>

    <!-- 삭제되지 않은 배정과 삭제되지 않은 현장만 담당 현장으로 조회 -->
    <select id="findActiveAssignmentsByUserId" resultMap="userSiteAssignmentResultMap">
        SELECT
            us.mapping_id,
            us.user_id,
            us.site_id,
            s.name AS site_name,
            s.address AS site_address,
            us.assigned_at
        FROM user_site us
        INNER JOIN site s ON s.site_id = us.site_id
        WHERE us.user_id = #{userId}
          AND us.deleted_at IS NULL
          AND s.deleted_at IS NULL
        ORDER BY s.site_id DESC
    </select>
</mapper>
