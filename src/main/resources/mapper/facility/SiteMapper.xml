<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rayworld.firesafety.facility.mapper.SiteMapper">
    <resultMap id="siteResultMap" type="com.rayworld.firesafety.facility.model.Site">
        <id property="siteId" column="site_id"/>
        <result property="name" column="name"/>
        <result property="address" column="address"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <resultMap id="facilityAuditLogResultMap" type="com.rayworld.firesafety.facility.model.FacilityAuditLog">
        <id property="auditId" column="audit_id"/>
        <result property="targetType" column="target_type"/>
        <result property="targetId" column="target_id"/>
        <result property="actorUserId" column="actor_user_id"/>
        <result property="action" column="action"/>
        <result property="beforeData" column="before_data"/>
        <result property="afterData" column="after_data"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="facilityAuditLogFilter">
        <where>
            <if test="targetType != null">
                AND target_type = #{targetType}
            </if>
            <if test="targetId != null">
                AND target_id = #{targetId}
            </if>
            <if test="actorUserId != null">
                AND actor_user_id = #{actorUserId}
            </if>
            <if test="action != null">
                AND action = #{action}
            </if>
            <if test="fromAt != null">
                AND created_at &gt;= #{fromAt}
            </if>
            <if test="toAt != null">
                AND created_at &lt; #{toAt}
            </if>
        </where>
    </sql>

    <!-- 최고관리자가 신규 현장을 등록 -->
    <insert id="insertSite"
            parameterType="com.rayworld.firesafety.facility.model.Site"
            useGeneratedKeys="true"
            keyProperty="siteId">
        INSERT INTO site (
            name,
            address
        ) VALUES (
            #{name},
            #{address}
        )
    </insert>

    <!-- 등록/수정/삭제 대상 현장 활성 여부 확인 -->
    <select id="findActiveSiteById" resultMap="siteResultMap">
        SELECT
            site_id,
            name,
            address,
            created_at,
            updated_at,
            deleted_at
        FROM site
        WHERE site_id = #{siteId}
          AND deleted_at IS NULL
    </select>

    <!-- SUPER_ADMIN은 전체 활성 현장 조회 -->
    <select id="findActiveSites" resultMap="siteResultMap">
        SELECT
            site_id,
            name,
            address,
            created_at,
            updated_at,
            deleted_at
        FROM site
        WHERE deleted_at IS NULL
        ORDER BY site_id DESC
    </select>

    <!-- ADMIN/GENERAL은 배정된 활성 현장만 조회 -->
    <select id="findActiveSitesByUserId" resultMap="siteResultMap">
        SELECT
            s.site_id,
            s.name,
            s.address,
            s.created_at,
            s.updated_at,
            s.deleted_at
        FROM site s
        INNER JOIN user_site us ON us.site_id = s.site_id
        WHERE us.user_id = #{userId}
          AND us.deleted_at IS NULL
          AND s.deleted_at IS NULL
        ORDER BY s.site_id DESC
    </select>

    <!-- ADMIN/GENERAL이 해당 현장에 배정되어 있는지 확인 -->
    <select id="existsActiveSiteAssignment" resultType="boolean">
        SELECT EXISTS(
            SELECT 1
            FROM user_site us
            INNER JOIN site s ON s.site_id = us.site_id
            WHERE us.user_id = #{userId}
              AND us.site_id = #{siteId}
              AND us.deleted_at IS NULL
              AND s.deleted_at IS NULL
        )
    </select>

    <!-- 최고관리자가 현장 기본 정보를 수정 -->
    <update id="updateSite" parameterType="com.rayworld.firesafety.facility.model.Site">
        UPDATE site
        SET name = #{name},
            address = #{address},
            updated_at = CURRENT_TIMESTAMP
        WHERE site_id = #{siteId}
          AND deleted_at IS NULL
    </update>

    <!-- 현장 row는 보존하고 일반 조회 대상에서 제외 -->
    <update id="softDeleteSite">
        UPDATE site
        SET deleted_at = CURRENT_TIMESTAMP,
            updated_at = CURRENT_TIMESTAMP
        WHERE site_id = #{siteId}
          AND deleted_at IS NULL
    </update>

    <!-- 현장/분전반/회로 등록·수정·삭제 이력 저장 -->
    <insert id="insertFacilityAuditLog"
            parameterType="com.rayworld.firesafety.facility.model.FacilityAuditLog"
            useGeneratedKeys="true"
            keyProperty="auditId">
        INSERT INTO facility_audit_log (
            target_type,
            target_id,
            actor_user_id,
            action,
            before_data,
            after_data
        ) VALUES (
            #{targetType},
            #{targetId},
            #{actorUserId},
            #{action},
            #{beforeData},
            #{afterData}
        )
    </insert>

    <!-- SUPER_ADMIN 설비 감사 이력 필터 조회 -->
    <select id="findFacilityAuditLogs" resultMap="facilityAuditLogResultMap">
        SELECT
            audit_id,
            target_type,
            target_id,
            actor_user_id,
            action,
            before_data,
            after_data,
            created_at
        FROM facility_audit_log
        <include refid="facilityAuditLogFilter"/>
        ORDER BY audit_id DESC
        LIMIT #{size}
        OFFSET #{offset}
    </select>

    <!-- SUPER_ADMIN 설비 감사 이력 전체 개수 조회 -->
    <select id="countFacilityAuditLogs" resultType="long">
        SELECT COUNT(*)
        FROM facility_audit_log
        <include refid="facilityAuditLogFilter"/>
    </select>
</mapper>
