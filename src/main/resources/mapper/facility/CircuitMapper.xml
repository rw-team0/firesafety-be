<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rayworld.firesafety.facility.mapper.CircuitMapper">
    <resultMap id="circuitResultMap" type="com.rayworld.firesafety.facility.model.Circuit">
        <id property="circuitId" column="circuit_id"/>
        <result property="panelId" column="panel_id"/>
        <result property="channelNo" column="channel_no"/>
        <result property="loadType" column="load_type"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <!-- 분전반 아래 신규 회로 등록 -->
    <insert id="insertCircuit"
            parameterType="com.rayworld.firesafety.facility.model.Circuit"
            useGeneratedKeys="true"
            keyProperty="circuitId">
        INSERT INTO circuit (
            panel_id,
            channel_no,
            load_type
        ) VALUES (
            #{panelId},
            #{channelNo},
            #{loadType}
        )
    </insert>

    <!-- 등록/삭제 대상 회로 활성 여부 확인 -->
    <select id="findActiveCircuitById" resultMap="circuitResultMap">
        SELECT
            c.circuit_id,
            c.panel_id,
            c.channel_no,
            c.load_type,
            c.created_at,
            c.updated_at,
            c.deleted_at
        FROM circuit c
        INNER JOIN panel p ON p.panel_id = c.panel_id
        INNER JOIN site s ON s.site_id = p.site_id
        WHERE c.circuit_id = #{circuitId}
          AND c.deleted_at IS NULL
          AND p.deleted_at IS NULL
          AND s.deleted_at IS NULL
    </select>

    <!-- DB UNIQUE(panel_id, channel_no) 제약과 같은 범위로 중복 확인 -->
    <select id="existsCircuitByPanelIdAndChannelNo" resultType="boolean">
        SELECT EXISTS(
            SELECT 1
            FROM circuit
            WHERE panel_id = #{panelId}
              AND channel_no = #{channelNo}
        )
    </select>
</mapper>
