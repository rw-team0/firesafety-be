<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rayworld.firesafety.facility.mapper.PanelMapper">
    <resultMap id="panelResultMap" type="com.rayworld.firesafety.facility.model.Panel">
        <id property="panelId" column="panel_id"/>
        <result property="siteId" column="site_id"/>
        <result property="name" column="name"/>
        <result property="deviceSerial" column="device_serial"/>
        <result property="mNo" column="m_no"/>
        <result property="installedAt" column="installed_at"/>
        <result property="status" column="status"/>
        <result property="isOnline" column="is_online"/>
        <result property="lastCommunicatedAt" column="last_communicated_at"/>
        <result property="circuitCount" column="circuit_count"/>
        <result property="leakMaThreshold" column="leak_ma_threshold"/>
        <result property="tempThreshold" column="temp_threshold"/>
        <result property="humidityThreshold" column="humidity_threshold"/>
        <result property="overcurrentThreshold" column="overcurrent_threshold"/>
        <result property="gasThreshold" column="gas_threshold"/>
        <result property="fireThreshold" column="fire_threshold"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <!-- 현장 아래 신규 분전반 등록 -->
    <insert id="insertPanel"
            parameterType="com.rayworld.firesafety.facility.model.Panel"
            useGeneratedKeys="true"
            keyProperty="panelId">
        INSERT INTO panel (
            site_id,
            name,
            device_serial,
            m_no,
            installed_at,
            status,
            is_online,
            circuit_count,
            leak_ma_threshold,
            temp_threshold,
            humidity_threshold,
            overcurrent_threshold,
            gas_threshold,
            fire_threshold
        ) VALUES (
            #{siteId},
            #{name},
            #{deviceSerial},
            #{mNo},
            #{installedAt},
            #{status},
            #{isOnline},
            #{circuitCount},
            #{leakMaThreshold},
            #{tempThreshold},
            #{humidityThreshold},
            #{overcurrentThreshold},
            #{gasThreshold},
            #{fireThreshold}
        )
    </insert>

    <!-- 등록/수정/삭제 대상 분전반 활성 여부 확인 -->
    <select id="findActivePanelById" resultMap="panelResultMap">
        SELECT
            panel_id,
            site_id,
            name,
            device_serial,
            m_no,
            installed_at,
            status,
            is_online,
            last_communicated_at,
            circuit_count,
            leak_ma_threshold,
            temp_threshold,
            humidity_threshold,
            overcurrent_threshold,
            gas_threshold,
            fire_threshold,
            created_at,
            updated_at,
            deleted_at
        FROM panel
        WHERE panel_id = #{panelId}
          AND deleted_at IS NULL
    </select>

    <!-- 장비 시리얼 중복 등록 방지 -->
    <select id="existsPanelByDeviceSerial" resultType="boolean">
        SELECT EXISTS(
            SELECT 1
            FROM panel
            WHERE device_serial = #{deviceSerial}
        )
    </select>
</mapper>
